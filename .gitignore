# ---- large data / weights / outputs (do NOT upload) ----
data/                       # CelebV-HQ raw videos, frames, aligned faces, dataset zips
ckpts/                      # pretrained + trained model weights (*.pkl)
runs/                       # training snapshots, FID jsonl, feature cache
submissions/                # generated image zips + pools
_do_not_submit/             # quarantined (rule-violating) zips
*.pkl
*.zip
*.npy
*.pt
*.pth

# ---- environments ----
env/ldm_venv/               # diffusers venv (recreate from requirements-ldm.txt)
__pycache__/
*.pyc

# ---- report / template (not part of the code repo) ----
deep_generative_model_templete/
report/figs/                # regenerated by scripts/make_*.py
report/*.aux
report/*.log
report/*.out
report/*.bbl
report/*.blg
# keep report/main.tex and report/main.pdf if you want them in-repo; otherwise ignore:
# report/main.pdf

# ---- misc ----
.DS_Store
*.tfevents.*

# report (submitted separately as PDF, not in the code repo)
report/
